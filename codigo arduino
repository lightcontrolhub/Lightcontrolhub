#include <WiFiS3.h>
#include <ArduinoHttpClient.h>

// ====== CONFIG ======
const char* WIFI_SSID = "2G_Netvirtua203";
const char* WIFI_PASS = "alysson2801";

// Firebase
// Projeto: https://console.firebase.google.com/
// Use Realtime Database (URL: https://<PROJECT_ID>-default-rtdb.firebaseio.com)
const char* FIREBASE_API_KEY = "SUA_FIREBASE_WEB_API_KEY";
const char* FIREBASE_PROJECT_ID = "seu-projeto-id"; // ex: lightcontrolhub-12345
const char* DATABASE_HOST = "seu-projeto-id-default-rtdb.firebaseio.com"; // sem "https://"
const char* DEVICE_ID = "dispositivo-do-breno";

// ====== CONSTANTES ======
const int LED_PIN = 13;

// ====== GLOBAIS ======
WiFiClient wifi;
WiFiSSLClient ssl; // HTTPS
HttpClient idClient(ssl, "identitytoolkit.googleapis.com", 443);
HttpClient dbClient(ssl, DATABASE_HOST, 443);

String idToken = "";
unsigned long tokenExpiresAt = 0; // millis futuro
unsigned long lastPoll = 0;
unsigned long pollInterval = 2000;

// Máquina de estado do LED pulse (10s ON / 2s OFF)
enum LedMode { MODE_OFF, MODE_ON, MODE_PULSE };
LedMode currentMode = MODE_OFF;

bool ledOn = false;
unsigned long phaseStart = 0;
const unsigned long ON_MS = 10000; // 10s
const unsigned long OFF_MS = 2000; // 2s

// ====== FUNÇÕES AUX ======
void ensureWiFi() {
if (WiFi.status() == WL_CONNECTED) return;
WiFi.begin(WIFI_SSID, WIFI_PASS);
while (WiFi.status() != WL_CONNECTED) {
delay(500);
}
}

bool refreshAnonToken() {
// Se token ainda válido por > 60s, mantém
if (idToken.length() > 0 && millis() + 60000 < tokenExpiresAt) return true;

// POST https://identitytoolkit.googleapis.com/v1/accounts:signUp?key=API_KEY
String path = "/v1/accounts:signUp?key=" + String(FIREBASE_API_KEY);
String body = "{\"returnSecureToken\":true}";
idClient.beginRequest();
idClient.post(path);
idClient.sendHeader("Content-Type", "application/json");
idClient.sendHeader("Content-Length", body.length());
idClient.beginBody();
idClient.print(body);
idClient.endRequest();

int status = idClient.responseStatusCode();
String resp = idClient.responseBody();

if (status != 200) {
// Falhou login anônimo
return false;
}

// Pegar idToken e expiresIn (em segundos)
// Parse simples (sem ArduinoJson) — cuidado com aspas
int tStart = resp.indexOf("\"idToken\":\"");
if (tStart < 0) return false;
tStart += 11;
int tEnd = resp.indexOf("\"", tStart);
idToken = resp.substring(tStart, tEnd);

int eStart = resp.indexOf("\"expiresIn\":\"");
if (eStart < 0) return false;
eStart += 13;
int eEnd = resp.indexOf("\"", eStart);
String expiresStr = resp.substring(eStart, eEnd);
unsigned long expiresSec = expiresStr.toInt();
if (expiresSec == 0) expiresSec = 3600;

tokenExpiresAt = millis() + (expiresSec * 1000UL);
return true;
}

String dbGet(const String& dbPath) {
// GET https://<dbhost>/<path>.json?auth=<idToken>
String url = dbPath + ".json?auth=" + idToken;

dbClient.beginRequest();
dbClient.get(url);
dbClient.sendHeader("Connection", "close");
dbClient.endRequest();

int status = dbClient.responseStatusCode();
String body = dbClient.responseBody();
if (status != 200) {
return "";
}
return body;
}

bool dbPatch(const String& dbPath, const String& jsonBody) {
// PATCH https://<dbhost>/<path>.json?auth=<idToken>
String url = dbPath + ".json?auth=" + idToken;

dbClient.beginRequest();
dbClient.patch(url);
dbClient.sendHeader("Content-Type", "application/json");
dbClient.sendHeader("Content-Length", jsonBody.length());
dbClient.beginBody();
dbClient.print(jsonBody);
dbClient.endRequest();

int status = dbClient.responseStatusCode();
String body = dbClient.responseBody();
return (status == 200);
}

LedMode parseModeFromJSON(const String& json) {
// Espera algo tipo: "off" | "on" | "pulse"
// Quando o valor é string pura no RTDB, o REST retorna com aspas, ex: "pulse"
if (json.indexOf("pulse") >= 0) return MODE_PULSE;
if (json.indexOf("on") >= 0) return MODE_ON;
if (json.indexOf("off") >= 0) return MODE_OFF;
// Se não existir, default "off"
return MODE_OFF;
}

void setLed(bool on) {
ledOn = on;
digitalWrite(LED_PIN, on ? HIGH : LOW);
}

void runPulseStateMachine() {
unsigned long now = millis();
if (ledOn) {
// fase ON
if (now - phaseStart >= ON_MS) {
setLed(false);
phaseStart = now;
}
} else {
// fase OFF
if (now - phaseStart >= OFF_MS) {
setLed(true);
phaseStart = now;
}
}
}

void publishStatus() {
// Publica estado e lastSeen
unsigned long now = millis();
String path = "/devices/" + String(DEVICE_ID) + "/status";
String body = String("{\"led13\":\"") + (ledOn ? "on" : "off") + "\",\"lastSeenMs\":" + now + "}";
dbPatch(path, body);
}

// ====== SETUP/LOOP ======
void setup() {
pinMode(LED_PIN, OUTPUT);
setLed(false);

ensureWiFi();
refreshAnonToken();

// Inicializa config default no DB (se quiser)
dbPatch("/devices/" + String(DEVICE_ID) + "/config", "{\"led13Mode\":\"off\"}");
}

void loop() {
ensureWiFi();
if (!refreshAnonToken()) {
// Se não conseguir token, tenta de novo depois
delay(2000);
return;
}

// PUXA COMANDO A CADA pollInterval
unsigned long now = millis();
if (now - lastPoll >= pollInterval) {
lastPoll = now;

String modeJson = dbGet("/devices/" + String(DEVICE_ID) + "/config/led13Mode");
LedMode newMode = parseModeFromJSON(modeJson);

if (newMode != currentMode) {
currentMode = newMode;
// Ajusta estado inicial da máquina
if (currentMode == MODE_OFF) {
setLed(false);
} else if (currentMode == MODE_ON) {
setLed(true);
} else if (currentMode == MODE_PULSE) {
// inicia no ON
setLed(true);
phaseStart = now;
}
}

publishStatus(); // manda batimento pro DB
}

// Máquina de estado do pulse
if (currentMode == MODE_PULSE) {
runPulseStateMachine();
}

// Sem delay bloqueante — loop livre
}
